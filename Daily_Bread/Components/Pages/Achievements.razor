@page "/achievements"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using System.Security.Claims
@using Daily_Bread.Services
@using Daily_Bread.Data.Models

@inject IAchievementService AchievementService
@inject IAchievementBonusService BonusService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Achievements</PageTitle>

<div class="achievements-container">
    <!-- Header (#3d): title + unlocked count -->
    <div class="ach-head">
        <div>
            <h1 class="ach-title">Achievements</h1>
            @if (_stats != null)
            {
                <p class="ach-sub">@_stats.EarnedAchievements of @_stats.TotalAchievements unlocked · @_stats.EarnedPoints points</p>
            }
        </div>
        @if (_activeBonuses != null && _activeBonuses.ActiveBonuses.Count > 0)
        {
            <button type="button" class="ach-bonuses-btn" @onclick="() => _showBonusPanel = !_showBonusPanel">
                Bonuses <span class="ach-bonuses-count">@_activeBonuses.ActiveBonuses.Count</span>
            </button>
        }
    </div>

    @if (_showBonusPanel && _activeBonuses != null)
    {
        <div class="ach-bonus-panel">
            <div class="ach-bonus-head">
                <span>Active bonuses</span>
                <button type="button" class="ach-bonus-close" @onclick="() => _showBonusPanel = false" title="Close">
                    <IconTile IconName="circle-x" Mono="true" Size="14" />
                </button>
            </div>
            @if (_activeBonuses.PointMultiplier > 1)
            {
                <div class="bonus-item">Point multiplier: <strong>@_activeBonuses.PointMultiplier.ToString("P0")</strong></div>
            }
            @if (_activeBonuses.PenaltyReduction > 0)
            {
                <div class="bonus-item">Penalty reduction: <strong>@_activeBonuses.PenaltyReduction.ToString("P0")</strong></div>
            }
            @if (_activeBonuses.ForgivenessUsesAvailable > 0)
            {
                <div class="bonus-item">Forgiveness: <strong>@_activeBonuses.ForgivenessUsesAvailable use(s)</strong></div>
            }
            @if (_activeBonuses.StreakProtectionAvailable > 0)
            {
                <div class="bonus-item">Streak protection: <strong>@_activeBonuses.StreakProtectionAvailable use(s)</strong></div>
            }
            @if (_activeBonuses.DoublePointDaysAvailable > 0)
            {
                <div class="bonus-item">Double point days: <strong>@_activeBonuses.DoublePointDaysAvailable day(s)</strong></div>
            }
            @if (_activeBonuses.ProfileBadges.Count > 0)
            {
                <div class="bonus-item">Badges: <strong>@string.Join(", ", _activeBonuses.ProfileBadges)</strong></div>
            }
        </div>
    }

    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_unseenAchievements.Count > 0)
    {
        <!-- Recent-unlock banner (celebration surface — emoji allowed) -->
        <div class="ach-unlock">
            @foreach (var achievement in _unseenAchievements)
            {
                <div class="ach-unlock-row" @onclick="() => ShowAchievementDetail(achievement)">
                    <span class="ach-unlock-badge">@achievement.Icon</span>
                    <div class="ach-unlock-info">
                        <div class="ach-unlock-name">@achievement.Name</div>
                        <div class="ach-unlock-desc">Unlocked@(achievement.EarnedAt.HasValue ? $" {achievement.EarnedAt.Value:MMM d}" : "") · @achievement.Description</div>
                    </div>
                    @if (achievement.HasBonus)
                    {
                        <span class="ach-chip bonus" title="@achievement.BonusDescription">bonus</span>
                    }
                    <span class="ach-chip pts">+@achievement.Points pts</span>
                </div>
            }
            <button type="button" class="ach-unlock-dismiss" @onclick="MarkAllSeen">Awesome!</button>
        </div>
    }

    <!-- Category filter: one scrollable pill row (all breakpoints) -->
    <div class="ach-tabs">
        <button type="button" class="ach-tab @(_selectedCategory == null ? "active" : "")"
                @onclick="() => _selectedCategory = null">
            All (@_achievements.Count)
        </button>
        @foreach (var category in GetCategories())
        {
            var count = _achievements.Count(a => a.Category == category);
            var earned = _achievements.Count(a => a.Category == category && a.IsEarned);
            <button type="button" class="ach-tab @(_selectedCategory == category ? "active" : "")"
                    @onclick="() => _selectedCategory = category">
                @GetCategoryName(category) (@earned/@count)
            </button>
        }
    </div>

    <!-- Grid (#3d): unlocked = gradient medal · locked = conic progress ring -->
    <div class="ach-grid">
        @foreach (var achievement in GetFilteredAchievements())
        {
            var ringDeg = Math.Clamp(achievement.ProgressPercent, 0, 100) * 360 / 100;
            <button type="button"
                    class="ach-cell @(achievement.IsEarned ? "earned" : "locked")"
                    @onclick="() => ShowAchievementDetail(achievement)">
                @if (achievement.IsEarned)
                {
                    <span class="ach-medal">@achievement.Icon</span>
                }
                else
                {
                    <span class="ach-ring" style="background: conic-gradient(var(--db-accent) 0 @(ringDeg)deg, var(--ds-bg-selected) @(ringDeg)deg 360deg)">
                        <span class="ach-ring-inner">@(achievement.IsHidden ? "?" : (achievement.LockedIcon ?? achievement.Icon))</span>
                    </span>
                }
                <span class="ach-cell-name">@achievement.Name</span>
                <span class="ach-cell-sub">
                    @if (achievement.IsEarned)
                    {
                        @(achievement.EarnedAt?.ToString("MMM d, yyyy") ?? "Unlocked")
                    }
                    else if (achievement.ShowProgress)
                    {
                        @($"{achievement.CurrentProgress}/{achievement.TargetProgress}")
                    }
                    else if (achievement.IsHidden)
                    {
                        @("Secret")
                    }
                    else
                    {
                        @("Locked")
                    }
                </span>
                @if (achievement.HasBonus)
                {
                    <span class="ach-cell-bonus" title="@achievement.BonusDescription">+bonus</span>
                }
            </button>
        }
    </div>

    @if (_stats != null && _stats.HiddenRemaining > 0)
    {
        <div class="ach-hidden-note">
            @_stats.HiddenRemaining hidden achievement@(_stats.HiddenRemaining > 1 ? "s" : "") remaining
        </div>
    }
</div>

<!-- Achievement Detail Modal (all breakpoints) -->
@if (_selectedAchievement != null)
{
    <div class="ach-modal-backdrop" @onclick="() => _selectedAchievement = null">
        <div class="ach-modal" @onclick:stopPropagation="true">
            <div class="ach-modal-head">
                <span class="ach-chip rarity">@GetRarityName(_selectedAchievement.Rarity)</span>
                <button type="button" class="ach-bonus-close" @onclick="() => _selectedAchievement = null" title="Close">
                    <IconTile IconName="circle-x" Mono="true" Size="16" />
                </button>
            </div>
            <div class="ach-modal-body">
                @if (_selectedAchievement.IsEarned)
                {
                    <span class="ach-medal big">@_selectedAchievement.Icon</span>
                }
                else
                {
                    <span class="ach-ring big" style="background: conic-gradient(var(--db-accent) 0 @(Math.Clamp(_selectedAchievement.ProgressPercent, 0, 100) * 360 / 100)deg, var(--ds-bg-selected) @(Math.Clamp(_selectedAchievement.ProgressPercent, 0, 100) * 360 / 100)deg 360deg)">
                        <span class="ach-ring-inner">@(_selectedAchievement.IsHidden ? "?" : (_selectedAchievement.LockedIcon ?? _selectedAchievement.Icon))</span>
                    </span>
                }
                <h4 class="ach-modal-name">@_selectedAchievement.Name</h4>
                <p class="ach-modal-desc">@_selectedAchievement.Description</p>

                @if (_selectedAchievement.IsEarned)
                {
                    <div class="ach-modal-earned">Unlocked on @_selectedAchievement.EarnedAt?.ToString("MMM d, yyyy")</div>
                }
                else if (_selectedAchievement.ShowProgress)
                {
                    <div class="ach-modal-progress">
                        <span class="ach-modal-bar">
                            <span class="ach-modal-fill" style="width: @_selectedAchievement.ProgressPercent%"></span>
                        </span>
                        <span class="ach-modal-count">@_selectedAchievement.CurrentProgress / @_selectedAchievement.TargetProgress</span>
                    </div>
                }

                @if (_selectedAchievement.HasBonus)
                {
                    <div class="ach-modal-bonus">
                        <strong>Bonus reward</strong>
                        <span>@_selectedAchievement.BonusDescription</span>
                    </div>
                }

                <span class="ach-chip pts">+@_selectedAchievement.Points points</span>
            </div>
        </div>
    </div>
}

@code {
    private string? _userId;
    private List<AchievementDisplay> _achievements = new();
    private List<AchievementDisplay> _unseenAchievements = new();
    private AchievementStats? _stats;
    private ActiveBonusSummary? _activeBonuses;
    private AchievementDisplay? _selectedAchievement;
    private AchievementCategory? _selectedCategory;
    private bool _isLoading = true;
    private bool _showBonusPanel;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(_userId)) return;

        _isLoading = true;

        try
        {
            // Check for newly earned achievements first
            await AchievementService.CheckAndAwardAchievementsAsync(_userId);
            
            _achievements = await AchievementService.GetAllAchievementsAsync(_userId);
            _unseenAchievements = _achievements.Where(a => a.IsNew).ToList();
            _stats = await AchievementService.GetStatsAsync(_userId);
            _activeBonuses = await BonusService.GetActiveBonusesAsync(_userId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading achievements: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task MarkAllSeen()
    {
        if (string.IsNullOrEmpty(_userId)) return;

        await AchievementService.MarkAchievementsAsSeenAsync(_userId);
        _unseenAchievements.Clear();

        // Refresh to update the IsNew flags
        _achievements = await AchievementService.GetAllAchievementsAsync(_userId);
    }

    private void ShowAchievementDetail(AchievementDisplay achievement)
    {
        _selectedAchievement = achievement;
    }

    private IEnumerable<AchievementCategory> GetCategories()
    {
        return _achievements
            .Select(a => a.Category)
            .Distinct()
            .OrderBy(c => c);
    }

    private IEnumerable<AchievementDisplay> GetFilteredAchievements()
    {
        var filtered = _selectedCategory.HasValue
            ? _achievements.Where(a => a.Category == _selectedCategory.Value)
            : _achievements;

        return filtered.OrderBy(a => !a.IsEarned).ThenBy(a => a.SortOrder);
    }

    private string GetCategoryName(AchievementCategory category)
    {
        return category switch
        {
            AchievementCategory.GettingStarted => "Getting Started",
            AchievementCategory.Streaks => "Streaks",
            AchievementCategory.Earnings => "Earnings",
            AchievementCategory.Consistency => "Consistency",
            AchievementCategory.Special => "Special",
            AchievementCategory.Secret => "Secret",
            AchievementCategory.Legendary => "Legendary",
            AchievementCategory.TimeBased => "Time",
            AchievementCategory.Social => "Social",
            AchievementCategory.Savings => "Savings",
            AchievementCategory.Mastery => "Mastery",
            _ => category.ToString()
        };
    }

    private string GetRarityName(AchievementRarity rarity)
    {
        return rarity switch
        {
            AchievementRarity.Common => "Common",
            AchievementRarity.Uncommon => "Uncommon",
            AchievementRarity.Rare => "Rare",
            AchievementRarity.Epic => "Epic",
            AchievementRarity.Legendary => "LEGENDARY",
            _ => ""
        };
    }
}
