@page "/chore-planner"
@page "/chore-planner/{WeekOffsetParam:int}"
@attribute [Authorize(Roles = "Parent")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using System.Security.Claims
@using Daily_Bread.Data.Models
@using Daily_Bread.Services
@using Daily_Bread.Components.Shared

@inject IChorePlannerService PlannerService
@inject IChildProfileService ProfileService
@inject IChoreManagementService ChoreManagementService
@inject IDateProvider DateProvider
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ModalService ModalService

<PageTitle>Planner</PageTitle>

<div class="labor-planner">
    <!-- Header (#3a / #3b): loaf mark + title · week nav pill · segmented tabs · + Add -->
    <header class="board-header no-print">
        <div class="header-content">
            <div class="header-brand">
                <h1 class="board-title">
                    <LoafMark Size="26" />
                    <span>Planner</span>
                </h1>
                @if (_childProfiles.Count > 1)
                {
                    <div class="child-selector">
                        <select class="child-select" @bind="_selectedUserId" @bind:after="LoadDataAsync">
                            <option value="">All Kids</option>
                            @foreach (var child in _childProfiles)
                            {
                                <option value="@child.UserId">@child.DisplayName</option>
                            }
                        </select>
                    </div>
                }
            </div>
            <div class="header-tools">
                <div class="week-pill">
                    <button class="nav-btn" @onclick="PreviousWeek" disabled="@_isNavigating" aria-label="Previous week">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                    </button>
                    <span class="week-label">@(_plannerData?.WeekLabel ?? "Loading...")</span>
                    @if (_weekOffset != 0)
                    {
                        <button class="today-link" @onclick="GoToCurrentWeek" disabled="@_isNavigating">
                            Back to this week
                        </button>
                    }
                    <button class="nav-btn" @onclick="NextWeek" disabled="@_isNavigating" aria-label="Next week">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
                    </button>
                </div>
                <div class="seg-control">
                    <button class="seg-btn @(_activeTab == TabView.Wages ? "active" : "")"
                            @onclick="() => SetActiveTab(TabView.Wages)">
                        <span>Tasks</span>
                        <span class="seg-count">@_earningChores.Count</span>
                    </button>
                    <button class="seg-btn @(_activeTab == TabView.Routines ? "active" : "")"
                            @onclick="() => SetActiveTab(TabView.Routines)">
                        <span>Routines</span>
                        <span class="seg-count">@_routineChores.Count</span>
                    </button>
                </div>
                <button class="add-btn" @onclick="ShowCreateChoreForm" title="Add a task">
                    <span class="bi bi-plus-lg" aria-hidden="true"></span>
                    <span class="btn-text">Add</span>
                </button>
            </div>
        </div>
    </header>

    <!-- Content -->
    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>Loading planner...</p>
        </div>
    }
    else if (_plannerData == null)
    {
        <div class="empty-state">
            <span class="empty-icon"><IconTile IconName="scroll-text" Mono="true" Size="40" /></span>
            <h3>No chores yet</h3>
            <p>Add your first task to get started!</p>
            <button class="primary-btn" @onclick="ShowCreateChoreForm">
                <span class="bi bi-plus-lg"></span> Add Labor
            </button>
        </div>
    }
    else
    {
        <!-- Wages Tab Content -->
        @if (_activeTab == TabView.Wages)
        {
            @if (_earningChores.Count == 0)
            {
                <div class="empty-state">
                    <span class="empty-icon"><IconTile IconName="wallet" Mono="true" Size="40" /></span>
                    <h3>No earning chores</h3>
                    <p>Add chores with a dollar value to see them here.</p>
                    <button class="primary-btn" @onclick="ShowCreateChoreForm">
                        <span class="bi bi-plus-lg"></span> Add Earning Chore
                    </button>
                </div>
            }
            else
            {
                <WageGrid
                    PlannerData="_plannerData"
                    EarningChores="_earningChores"
                    SelectedUserId="_selectedUserId"
                    UpdatingCellKey="_updatingCellKey"
                    OnEditChore="ShowEditChoreForm"
                    OnCellClick="HandleCellClickFromGrid"
                    EnableReorder="@(!string.IsNullOrEmpty(_selectedUserId))"
                    OnReorder="HandleWageReorder"
                    ExpandedChoreId="_expandedChoreId"
                    ExpandedChoreDetails="_expandedChoreDetails"
                    OnToggleExpand="HandleToggleExpand"
                    OnQuickUpdate="HandleQuickUpdate" />

                <!-- Footer: weekly potential + override count + hint (no legend, per #3a) -->
                <div class="planner-footer no-print">
                    <div class="pf-left">
                        <span class="pf-potential">
                            <span class="pf-label">Weekly potential</span>
                            <span class="pf-value">$@_plannerData.TotalWeeklyPotential.ToString("F2")</span>
                        </span>
                        @if (_plannerData.Overrides.Any())
                        {
                            <button class="pf-overrides" @onclick="() => _showOverrides = !_showOverrides">
                                <span class="pf-zap" aria-hidden="true">⚡</span>
                                <span>@_plannerData.Overrides.Count override@(_plannerData.Overrides.Count != 1 ? "s" : "") this week</span>
                                <span class="bi @(_showOverrides ? "bi-chevron-up" : "bi-chevron-down")" aria-hidden="true"></span>
                            </button>
                        }
                    </div>
                    <span class="pf-hint pf-hint-desktop">Tap a day = just this week · Open a row = the usual schedule</span>
                    <span class="pf-hint pf-hint-mobile">Tap a day = just this week · Open the card = the usual schedule</span>
                </div>

                @if (_showOverrides && _plannerData.Overrides.Any())
                {
                    <div class="overrides-list">
                        @foreach (var ovr in _plannerData.Overrides)
                        {
                            <div class="override-item">
                                <span class="override-icon"><IconTile IconName="zap" Mono="true" Size="14" /></span>
                                <span class="override-chore">@ovr.ChoreName</span>
                                <span class="override-action @ovr.Type.ToString().ToLower()">
                                    @(ovr.Type == ScheduleOverrideType.Add ? "added to" : ovr.Type == ScheduleOverrideType.Remove ? "removed from" : "moved to")
                                </span>
                                <span class="override-date">@ovr.Date.ToString("ddd, MMM d")</span>
                            </div>
                        }
                    </div>
                }
            }
        }

        <!-- Routines Tab Content -->
        @if (_activeTab == TabView.Routines)
        {
            <div class="routines-filter-bar no-print">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="showInactiveRoutines"
                           @bind="_showInactiveRoutines" @bind:after="LoadDataAsync" />
                    <label class="form-check-label" for="showInactiveRoutines">Show inactive routines</label>
                </div>
            </div>

            @if (_routineChores.Count == 0)
            {
                <div class="empty-state">
                    <span class="empty-icon">✓</span>
                    <h3>No daily routines</h3>
                    <p>Add chores with $0 value to create routines.</p>
                    <button class="primary-btn" @onclick="ShowCreateRoutineForm">
                        <span class="bi bi-plus-lg"></span> Add Routine
                    </button>
                </div>
            }
            else
            {
                <RoutinesList
                    RoutineChores="_routineChores"
                    SelectedUserId="_selectedUserId"
                    OnEditChore="ShowEditChoreForm"
                    OnAddRoutine="ShowCreateRoutineForm"
                    EnableReorder="@(!string.IsNullOrEmpty(_selectedUserId))"
                    OnReorder="HandleRoutineReorder" />
            }
        }
    }
</div>

<!-- Toast Messages -->
@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="toast-message error no-print">
        <span class="bi bi-exclamation-circle"></span>
        @_errorMessage
        <button class="toast-close" @onclick="() => _errorMessage = null">×</button>
    </div>
}

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="toast-message success no-print">
        <span class="bi bi-check-circle"></span>
        @_successMessage
        <button class="toast-close" @onclick="() => _successMessage = null">×</button>
    </div>
}

@code {
    private enum TabView { Wages, Routines }

    [Parameter]
    public int? WeekOffsetParam { get; set; }

    private int _weekOffset;
    private TabView _activeTab = TabView.Wages;
    private bool _isLoading = true;
    private bool _isNavigating = false;
    private bool _isRoutineMode = false;
    private string? _errorMessage;
    private string? _successMessage;
    private string? _currentUserId;
    private string? _selectedUserId;
    private bool _showOverrides = false;
    private bool _showInactiveRoutines = false;
#pragma warning disable CS0414 // Field is assigned but never read - used for state tracking with ModalService
    private bool _showChoreForm = false;
#pragma warning restore CS0414

    private ChorePlannerData? _plannerData;
    private List<ChildProfileSummary> _childProfiles = [];
    private List<UserSelectItem> _assignableUsers = [];
    private ChoreDefinitionDto? _editingChore;
    private string? _updatingCellKey;

    // Inline settings panel (expanded row/card) — recurring-schedule quick edits.
    private int? _expandedChoreId;
    private ChoreDefinitionDto? _expandedChoreDetails;

    // Filtered chore lists - visual only, all chores still loaded
    private List<ChorePlannerRow> _earningChores = [];
    private List<ChorePlannerRow> _routineChores = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        _weekOffset = WeekOffsetParam ?? 0;

        _childProfiles = await ProfileService.GetAllChildProfilesAsync();
        _assignableUsers = await ChoreManagementService.GetAssignableUsersAsync();

        if (_childProfiles.Count == 1)
        {
            _selectedUserId = _childProfiles[0].UserId;
        }

        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (WeekOffsetParam.HasValue && WeekOffsetParam.Value != _weekOffset)
        {
            _weekOffset = WeekOffsetParam.Value;
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var today = DateProvider.Today;
            var weekStart = PlannerService.GetWeekStart(today).AddDays(_weekOffset * 7);

            // Load ALL active chores, plus inactive ones if "Show inactive" is on
            _plannerData = await PlannerService.GetPlannerDataAsync(weekStart, _selectedUserId, includeInactive: _showInactiveRoutines);

            // Visual separation only - all chores participate in scheduling.
            // Wages tab is intentionally never shown inactive chores - "Show inactive" is scoped to Routines.
            var allChores = _plannerData.Groups.SelectMany(g => g.Chores).ToList();
            _earningChores = allChores.Where(c => c.IsEarningChore && c.IsActive).ToList();
            _routineChores = allChores.Where(c => !c.IsEarningChore).ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SetActiveTab(TabView tab)
    {
        _activeTab = tab;
    }

    private async Task PreviousWeek()
    {
        if (_isNavigating) return;
        _isNavigating = true;
        try { _weekOffset--; await LoadDataAsync(); }
        finally { _isNavigating = false; }
    }

    private async Task NextWeek()
    {
        if (_isNavigating) return;
        _isNavigating = true;
        try { _weekOffset++; await LoadDataAsync(); }
        finally { _isNavigating = false; }
    }

    private async Task GoToCurrentWeek()
    {
        if (_isNavigating) return;
        _isNavigating = true;
        try { _weekOffset = 0; await LoadDataAsync(); }
        finally { _isNavigating = false; }
    }

    private async Task HandleCellClickFromGrid((ChorePlannerRow Chore, ChorePlannerCell Cell) args)
    {
        await HandleCellClick(args.Chore, args.Cell);
    }

    private async Task HandleCellClick(ChorePlannerRow chore, ChorePlannerCell cell)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;

        if (cell.IsPast)
        {
            _errorMessage = "Cannot modify past dates.";
            ClearMessageAfterDelay();
            return;
        }

        var cellKey = $"{chore.ChoreDefinitionId}_{cell.Date:yyyyMMdd}";
        if (_updatingCellKey == cellKey) return;

        _updatingCellKey = cellKey;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var result = await PlannerService.ToggleOverrideAsync(chore.ChoreDefinitionId, cell.Date, _currentUserId);

            if (result.Success)
            {
                await LoadDataAsync();
                _successMessage = "Schedule updated!";
                ClearMessageAfterDelay();
            }
            else
            {
                _errorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _updatingCellKey = null;
            StateHasChanged();
        }
    }

    private void ClearMessageAfterDelay()
    {
        _ = Task.Delay(2500).ContinueWith(_ => InvokeAsync(() =>
        {
            _successMessage = null;
            _errorMessage = null;
            StateHasChanged();
        }));
    }

    private void ShowCreateChoreForm()
    {
        _isRoutineMode = false;
        _editingChore = new ChoreDefinitionDto
        {
            ActiveDays = DaysOfWeek.All,
            IsActive = true,
            EarnValue = 1.00m
        };
        _showChoreForm = true;
        OpenChoreModal();
    }

    private void ShowCreateRoutineForm()
    {
        _isRoutineMode = true;
        _editingChore = new ChoreDefinitionDto
        {
            ActiveDays = DaysOfWeek.All,
            IsActive = true,
            EarnValue = 0m
        };
        _showChoreForm = true;
        OpenChoreModal();
    }

    private async Task ShowEditChoreForm(ChorePlannerRow chore)
    {
        try
        {
            var choreDetails = await ChoreManagementService.GetChoreByIdAsync(chore.ChoreDefinitionId);
            if (choreDetails != null)
            {
                _isRoutineMode = choreDetails.Kind == ChoreKind.Routine;
                _editingChore = ToDto(choreDetails);
                _showChoreForm = true;
                OpenChoreModal();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading chore: {ex.Message}";
        }
    }

    private static ChoreDefinitionDto ToDto(ChoreDefinition c) => new()
    {
        Id = c.Id,
        Name = c.Name,
        Description = c.Description,
        Icon = c.Icon,
        LucideIconName = c.LucideIconName,
        TileSlot = c.TileSlot,
        AssignedUserId = c.AssignedUserId,
        Kind = c.Kind,
        EarnValue = c.EarnValue,
        Importance = c.Importance,
        AllOrNothing = c.AllOrNothing,
        IsInverseFill = c.IsInverseFill,
        InverseFillBaselineMinutes = c.InverseFillBaselineMinutes,
        ScheduleType = c.ScheduleType,
        ActiveDays = c.ActiveDays,
        WeeklyTargetCount = c.WeeklyTargetCount,
        IsRepeatable = c.IsRepeatable,
        StartDate = c.StartDate,
        EndDate = c.EndDate,
        IsActive = c.IsActive,
        AutoApprove = c.AutoApprove,
        SortOrder = c.SortOrder
    };

    /// <summary>
    /// Row/card header tap: toggle the inline settings panel and load full details
    /// for it (pay, usual days, auto-approve — the recurring schedule).
    /// </summary>
    private async Task HandleToggleExpand(ChorePlannerRow chore)
    {
        if (_expandedChoreId == chore.ChoreDefinitionId)
        {
            _expandedChoreId = null;
            _expandedChoreDetails = null;
            return;
        }

        _expandedChoreId = chore.ChoreDefinitionId;
        _expandedChoreDetails = null;

        try
        {
            var details = await ChoreManagementService.GetChoreByIdAsync(chore.ChoreDefinitionId);
            if (details != null && _expandedChoreId == chore.ChoreDefinitionId)
            {
                _expandedChoreDetails = ToDto(details);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading chore: {ex.Message}";
            _expandedChoreId = null;
            ClearMessageAfterDelay();
        }
    }

    /// <summary>
    /// Instant save from the inline panel. On failure the panel reverts to the
    /// stored values and the existing error toast shows.
    /// </summary>
    private async Task HandleQuickUpdate(ChoreDefinitionDto dto)
    {
        _errorMessage = null;

        try
        {
            var result = await ChoreManagementService.UpdateChoreAsync(dto);

            if (result.Success)
            {
                await LoadDataAsync();
            }
            else
            {
                _errorMessage = result.ErrorMessage;
                ClearMessageAfterDelay();
                await RefreshExpandedDetailsAsync(dto.Id);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
            ClearMessageAfterDelay();
            await RefreshExpandedDetailsAsync(dto.Id);
        }
    }

    private async Task RefreshExpandedDetailsAsync(int choreId)
    {
        if (_expandedChoreId != choreId) return;

        try
        {
            var details = await ChoreManagementService.GetChoreByIdAsync(choreId);
            _expandedChoreDetails = details != null ? ToDto(details) : null;
        }
        catch
        {
            // Keep the last known panel state; the toast already reported the failure.
        }
    }

    private void OpenChoreModal()
    {
        var title = _editingChore?.Id > 0 
            ? $"Edit {(_isRoutineMode ? "Routine" : "Task")}" 
            : $"Add {(_isRoutineMode ? "Routine" : "Task")}";
        
        var editingChore = _editingChore;
        var assignableUsers = _assignableUsers;
        
        ModalService.Open(@<ChoreFormModal 
            Title="@title"
            Chore="editingChore"
            Users="assignableUsers"
            OnSubmit="HandleChoreFormSubmit"
            OnCancel="HideChoreForm" />, closeOnBackdropClick: true);
    }

    private void HideChoreForm()
    {
        _showChoreForm = false;
        _editingChore = null;
        ModalService.Close();
    }

    private async Task HandleChoreFormSubmit(ChoreDefinitionDto dto)
    {
        _errorMessage = null;
        bool isEdit = dto.Id > 0;

        var result = isEdit
            ? await ChoreManagementService.UpdateChoreAsync(dto)
            : await ChoreManagementService.CreateChoreAsync(dto);

        if (result.Success)
        {
            _successMessage = isEdit ? "Updated!" : "Created!";
            HideChoreForm();
            await LoadDataAsync();
            if (isEdit)
            {
                await RefreshExpandedDetailsAsync(dto.Id);
            }
            ClearMessageAfterDelay();
        }
        else
        {
            _errorMessage = result.ErrorMessage;
        }
    }

    private async Task HandleRoutineReorder(List<(int ChoreId, int SortOrder)> updates)
    {
        _errorMessage = null;

        var result = await ChoreManagementService.UpdateSortOrderBatchAsync(updates);
        
        if (result.Success)
        {
            await LoadDataAsync();
        }
        else
        {
            _errorMessage = result.ErrorMessage;
        }
    }

    private async Task HandleWageReorder(List<(int ChoreId, int SortOrder)> updates)
    {
        _errorMessage = null;

        var result = await ChoreManagementService.UpdateSortOrderBatchAsync(updates);
        
        if (result.Success)
        {
            await LoadDataAsync();
        }
        else
        {
            _errorMessage = result.ErrorMessage;
        }
    }
}
