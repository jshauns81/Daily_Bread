@page "/chore-chart"
@page "/chore-chart/{WeekOffset:int}"
@attribute [Authorize(Roles = "Parent")]

@inject NavigationManager NavigationManager

@* Legacy print chore-chart route retired — planner is the single scheduling surface. *@

@code {
    [Parameter]
    public int? WeekOffset { get; set; }

    protected override void OnInitialized()
    {
        var target = WeekOffset is int offset ? $"/chore-planner/{offset}" : "/chore-planner";
        NavigationManager.NavigateTo(target, replace: true);
    }
}
