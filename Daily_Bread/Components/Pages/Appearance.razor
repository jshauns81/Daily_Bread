@page "/appearance"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Appearance - Daily Bread</PageTitle>

@* Appearance (design #16a/#16b): theme preview cards + mode segmented. *@
<div class="appearance-container">
    <h1 class="appearance-title">Appearance</h1>
    <p class="appearance-subtitle">Choose a theme and light or dark mode. Saved on this device.</p>

    <ThemePicker />

    <p class="appearance-foot">
        Money keeps its role color in every theme; chore tiles follow the theme's palette.
    </p>
</div>

<style>
    .appearance-container {
        max-width: 640px;
        margin: 0 auto;
        padding: var(--ds-space-5) var(--ds-space-4);
    }
    .appearance-title {
        font-size: 20px;
        font-weight: var(--ds-font-bold);
        letter-spacing: -.3px;
        color: var(--db-text);
        margin: 0;
    }
    .appearance-subtitle {
        color: var(--ds-text-muted);
        font-size: var(--ds-text-sm);
        margin: 4px 0 var(--ds-space-5);
    }
    .appearance-foot {
        color: var(--db-text3);
        font-size: var(--ds-text-xs);
        margin-top: var(--ds-space-4);
        text-align: center;
    }
</style>
