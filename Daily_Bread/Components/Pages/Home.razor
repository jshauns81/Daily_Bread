@page "/"
@rendermode InteractiveServer
@implements IDisposable

@using System.Security.Claims
@using Daily_Bread.Components.Shared
@using Daily_Bread.Components.Home
@using Daily_Bread.Data.Models

@inject IAppStateService AppState
@inject IDashboardService DashboardService
@inject IChoreManagementService ChoreManagementService
@inject IAchievementService AchievementService
@inject ITrackerService TrackerService
@inject IDateProvider DateProvider
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILogger<Home> Logger

<PageTitle>Daily Bread - Home</PageTitle>

@* Confetti celebration when all chores complete *@
<Confetti IsActive="_showConfetti" OnComplete="() => _showConfetti = false" ParticleCount="60" />

@if (_isLoading)
{
    @* Loading skeleton for dashboard *@
    <div class="skeleton-dashboard">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <Skeleton Type="SkeletonType.Text" Width="200px" Height="32px" />
            <Skeleton Type="SkeletonType.Text" Width="180px" Height="20px" />
        </div>
        
        <div class="skeleton-dashboard-stats mb-4">
            <Skeleton Type="SkeletonType.StatCard" />
            <Skeleton Type="SkeletonType.StatCard" />
            <Skeleton Type="SkeletonType.StatCard" />
            <Skeleton Type="SkeletonType.StatCard" />
        </div>
        
        <div class="skeleton-dashboard-main">
            <Skeleton Type="SkeletonType.Card" />
            <Skeleton Type="SkeletonType.Card" />
        </div>
    </div>
}
else if (!_isAuthenticated)
{
    @* User is not authenticated - redirect will happen via auth system *@
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted">Redirecting to login...</p>
    </div>
}
else if (_isAdminOnly)
{
    <EmptyState Type="EmptyStateType.NoData" 
                Icon="👨‍💼" 
                Title="Admin Account"
                Message="This account is for user management only.">
        <ActionButton>
            <a href="/admin/users" class="btn btn-primary btn-lg">
                Go to User Management
            </a>
        </ActionButton>
    </EmptyState>
}
else if ((_isParent || _isAdmin) && _parentData != null)
{
    <!-- Parent Dashboard (design #17a desktop / #17b mobile) -->
    <div class="dashboard-container db-dash">
        <!-- Hero: greeting + live chips + weekly earned-vs-potential bar -->
        <div class="card db-hero">
            <div class="db-hero-head">
                <h1 class="db-greeting">@Greeting()@(string.IsNullOrEmpty(_firstName) ? "" : ", ")<span class="db-greeting-name">@_firstName</span></h1>
                <div class="db-hero-date">@DateProvider.Now.ToString("dddd, MMMM d")</div>
            </div>
            <div class="db-chips">
                <span class="db-chip acc"><span class="db-chip-dot"></span>@_parentData.PendingApprovals.Count awaiting approval</span>
                <span class="db-chip money"><span class="db-chip-dot"></span>@_parentData.TodayCompletedCount done today</span>
                <span class="db-chip risk"><span class="db-chip-dot"></span>@_parentData.TodayHelpCount needs help</span>
            </div>
            <div class="db-hero-bar">
                @if (_parentData.WeeklyPotential > 0)
                {
                    <div class="db-pbar">
                        <div class="db-pbar-track-wrap @(_parentData.ThisWeekEarnings > 0 ? "has-marker" : "")">
                            @if (_parentData.ThisWeekEarnings > 0)
                            {
                                <div class="db-pbar-marker" style="left: @WeeklyMarkerPercent().ToString("0.##")%">
                                    <span class="db-pbar-bubble">$@_parentData.ThisWeekEarnings.ToString("F2")</span>
                                    <span class="db-pbar-caret"></span>
                                </div>
                            }
                            <div class="db-pbar-track">
                                <div class="db-pbar-fill" style="width: @WeeklyFillPercent().ToString("0.##")%"></div>
                            </div>
                        </div>
                        <div class="db-pbar-labels">
                            <span class="db-pbar-label-left">$0</span>
                            <span class="db-pbar-label-right">this week · $@_parentData.WeeklyPotential.ToString("F2") possible</span>
                        </div>
                    </div>
                }
                else
                {
                    <span class="db-hero-potential-amt">@WeeklyPotentialDisplay()</span>
                    <span class="db-hero-potential-label">earned this week</span>
                }
            </div>
        </div>

        <!-- Asymmetric grid: action column + rail -->
        <div class="db-grid">
            <div class="db-col">
                <div class="card db-approvals @(_parentData.PendingApprovals.Count > 0 ? "is-glowing" : "")">
                    <div class="db-card-head">
                        <h2 class="db-card-title">Pending approvals</h2>
                        @if (_parentData.PendingApprovals.Count > 0)
                        {
                            <span class="db-count">@_parentData.PendingApprovals.Count</span>
                        }
                    </div>
                    @if (_parentData.PendingApprovals.Count == 0)
                    {
                        <EmptyState Type="EmptyStateType.NoChores"
                                    Title="All caught up!"
                                    Message="No tasks waiting for approval."
                                    CssClass="empty-state-compact" />
                    }
                    else
                    {
                        <div class="db-appr-list">
                            @foreach (var item in _parentData.PendingApprovals.Take(6))
                            {
                                <div class="db-appr">
                                    <span class="db-appr-tile">
                                        <IconTile IconName="@ChoreTileIcon(item.ChoreDefinitionId)" Slot="@ChoreTileSlot(item.ChoreDefinitionId)" Size="30" />
                                    </span>
                                    <div class="db-appr-info">
                                        <div class="db-appr-t">@item.ChoreName</div>
                                        <div class="db-appr-m">
                                            @if (!IsSingleChild)
                                            {
                                                <span class="user-name">@item.ChildName</span>@(item.CompletedAt.HasValue ? " · " : "")
                                            }
                                            @(item.CompletedAt.HasValue ? GetTimeAgo(item.CompletedAt.Value) : "")<span class="db-appr-amt-inline">@((!IsSingleChild || item.CompletedAt.HasValue) ? " · " : "")$@item.Value.ToString("F2")</span>
                                        </div>
                                    </div>
                                    <span class="db-appr-amt">$@item.Value.ToString("F2")</span>
                                    <button class="db-btn-approve" @onclick="() => QuickApprove(item.ChoreLogId)" disabled="@_isApproving" title="Approve this task">
                                        @if (_approvingId == item.ChoreLogId)
                                        {
                                            <span class="spinner-border spinner-border-sm"></span>
                                        }
                                        else
                                        {
                                            <text>✓ Approve</text>
                                        }
                                    </button>
                                    <a href="/tracker/@item.Date.ToString("yyyy-MM-dd")" class="db-appr-view" title="Review in Activity">
                                        <span class="bi bi-eye"></span>
                                    </a>
                                </div>
                            }
                        </div>
                        @if (_parentData.PendingApprovals.Count > 6)
                        {
                            <a href="/tracker" class="db-viewall">View all (@_parentData.PendingApprovals.Count) in Activity →</a>
                        }
                    }
                </div>

                <div class="card db-quickview">
                    <div class="db-card-head"><h2 class="db-card-title">This week</h2></div>
                    <div class="db-week">
                        @foreach (var day in _parentData.WeekEarnings)
                        {
                            <div class="db-day @(day.Amount > 0 ? "on" : "") @(day.Date == DateProvider.Today ? "today" : "")">
                                <div class="db-day-d">@DayLetter(day.Date)</div>
                                <div class="db-day-v">@FormatDay(day.Amount)</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="db-col">
                @if (IsSingleChild)
                {
                    var child = _parentData.ChildrenBalances[0];
                    <!-- Single-child card variant (#17a right rail) — no other-child cues -->
                    <div class="card db-kid @(child.CanCashOut ? "ready" : "")">
                        <div class="db-kid-head">
                            <span class="db-kid-av">@(string.IsNullOrWhiteSpace(child.DisplayName) ? "?" : child.DisplayName.Trim().Substring(0, 1).ToUpper())</span>
                            <div class="db-kid-who">
                                <div class="db-kid-nm">@child.DisplayName</div>
                                <div class="db-kid-week">+$@_parentData.ThisWeekEarnings.ToString("F2") this week</div>
                            </div>
                            @if (child.CanCashOut)
                            {
                                <span class="db-kid-ready">CASH OUT READY</span>
                            }
                        </div>
                        <div class="db-kid-bal @(child.Balance < 0 ? "neg" : "")">$@child.Balance.ToString("F2")</div>
                        <div class="db-kid-bal-l">CURRENT BALANCE</div>
                        <div class="db-kid-actions">
                            <a href="/ledger/@child.ProfileId" class="db-kid-btn payout">Record payout</a>
                            <a href="/ledger/@child.ProfileId" class="db-kid-btn ledger">Open ledger →</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card db-children">
                        <div class="db-card-head"><h2 class="db-card-title">Children</h2></div>
                        @if (_parentData.ChildrenBalances.Count == 0)
                        {
                            <EmptyState Type="EmptyStateType.NoChildren" CssClass="empty-state-compact">
                                <ActionButton>
                                    <a href="/admin/users" class="btn btn-primary btn-sm">Add Children</a>
                                </ActionButton>
                            </EmptyState>
                        }
                        else
                        {
                            <div class="db-bal-list">
                                @foreach (var child in _parentData.ChildrenBalances)
                                {
                                    <a href="/ledger/@child.ProfileId" class="db-bal">
                                        <span class="db-bal-who">
                                            <span class="db-bal-av">@(string.IsNullOrWhiteSpace(child.DisplayName) ? "?" : child.DisplayName.Trim().Substring(0, 1).ToUpper())</span>
                                            <span class="db-bal-nm">@child.DisplayName</span>
                                            @if (child.CanCashOut)
                                            {
                                                <span class="db-bal-ready">Cash out ready</span>
                                            }
                                        </span>
                                        <span class="db-bal-amt @(child.Balance < 0 ? "neg" : "")">$@child.Balance.ToString("F2")</span>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }

                <div class="db-heat">
                    <YearActivityCard Compact="true" Heading="@HeatmapHeading()" />
                </div>
            </div>
        </div>
    </div>
}
else if ((_isParent || _isAdmin) && _parentData == null)
{
    @* Parent user but data failed to load *@
    <EmptyState Type="EmptyStateType.Error" 
                Title="Unable to Load Dashboard"
                Message="We couldn't load your parent dashboard data. Please try refreshing the page.">
        <ActionButton>
            <button class="btn btn-primary" @onclick="@(() => LoadDashboardAsync())">Try Again</button>
        </ActionButton>
    </EmptyState>
}
else if (_childData != null)
{
    <!-- Kid money home (design #12a merged with #12b records strip; goal/ETA block removed) -->
    <div class="kid-home">
        @* Achievement unlock celebration (emoji allowed: celebration surface) *@
        @if (_childData.NewAchievements.Count > 0)
        {
            <div class="kh-unlock">
                @foreach (var achievement in _childData.NewAchievements)
                {
                    <a href="/achievements" class="kh-unlock-row">
                        <span class="kh-unlock-badge">@achievement.Icon</span>
                        <span class="kh-unlock-info">
                            <span class="kh-unlock-name">@achievement.Name</span>
                            <span class="kh-unlock-desc">Unlocked! @achievement.Description</span>
                        </span>
                        <span class="kh-unlock-pts">+@achievement.Points pts</span>
                    </a>
                }
            </div>
        }

        <!-- Balance hero: balance is net worth -->
        <a href="/ledger" class="kh-hero">
            <div class="kh-hero-label">BALANCE</div>
            <div class="kh-hero-row">
                <AnimatedCounter Value="@_childData.Balance"
                                 Prefix="$"
                                 CssClass="kh-hero-amt"
                                 Duration="600" />
                @if (_childData.TodayEarnings > 0)
                {
                    <span class="kh-hero-today">+$@_childData.TodayEarnings.ToString("F2") today</span>
                }
            </div>
            <div class="kh-hero-sub">nothing ever gets taken back</div>
        </a>

        <!-- Records strip (#12b): his numbers, all verifiable-real -->
        <div class="kh-records">
            <div class="kh-cell">
                <div class="kh-cell-label">EARNED</div>
                <div class="kh-cell-value money">$@_childData.WeeklyStats.ThisWeekEarnings.ToString("F2")</div>
                <div class="kh-cell-sub">last week: $@_childData.WeeklyStats.LastWeekEarnings.ToString("F2")</div>
            </div>
            @if (FirstWeeklyProgress is { } weekly)
            {
                <div class="kh-cell">
                    <div class="kh-cell-label">@weekly.ChoreDefinition.Name.ToUpperInvariant()</div>
                    <div class="kh-cell-value">@weekly.CompletedCount<span class="kh-cell-denom">/@weekly.TargetCount</span></div>
                    <div class="kh-cell-sub">@WeeklyCellSub(weekly)</div>
                </div>
            }
            else
            {
                <div class="kh-cell">
                    <div class="kh-cell-label">TODAY</div>
                    <div class="kh-cell-value">@_childData.TodayCompletedCount<span class="kh-cell-denom">/@_childData.TodayTotalCount</span></div>
                    <div class="kh-cell-sub">done so far</div>
                </div>
            }
            <div class="kh-cell">
                <div class="kh-cell-label">STREAK</div>
                <div class="kh-cell-value">@_childData.CurrentStreak <span class="kh-cell-unit">@(_childData.CurrentStreak == 1 ? "day" : "days")</span></div>
                <div class="kh-cell-sub">best: @_childData.BestStreak @(_childData.BestStreak == 1 ? "day" : "days")</div>
            </div>
            <a href="/achievements" class="kh-cell">
                <div class="kh-cell-label">BADGES</div>
                <div class="kh-cell-value">@_childData.AchievementsEarned<span class="kh-cell-denom">/@_childData.TotalAchievements</span></div>
                <div class="kh-cell-sub">achievements unlocked</div>
            </a>
        </div>

        @* At-risk strip + screen-time bar intentionally not rendered: screen-time stakes are
           Phase 8, and the spec forbids an empty warning shell. *@

        <!-- NEXT UP: exactly one big next action -->
        @if (_childData.PendingChores.Count > 0)
        {
            var nextChore = _childData.PendingChores.First();
            var remainingChores = _childData.PendingChores.Skip(1).ToList();

            <div class="kh-next">
                <div class="kh-next-label">NEXT UP</div>
                <div class="kh-next-body">
                    <span class="kh-next-tile">
                        <IconTile IconName="@nextChore.LucideIconName" Slot="@nextChore.TileSlot" Size="40" />
                    </span>
                    <div class="kh-next-card">
                        <SwipeableChoreCard
                            Chore="@nextChore"
                            OnComplete="HandleChoreComplete"
                            OnRequestHelp="HandleHelpRequest"
                            OnUndo="HandleChoreUndo"
                            IsProcessing="@(_processingChoreId == nextChore.ChoreDefinitionId)" />
                    </div>
                </div>
                <div class="kh-swipe-hint">
                    <span class="kh-hint-help">← Help</span>
                    <span class="kh-hint-divider">swipe</span>
                    <span class="kh-hint-done">Done →</span>
                </div>
                @if (remainingChores.Count > 0)
                {
                    <button type="button" class="kh-more-toggle" @onclick="ToggleMoreToday">
                        @remainingChores.Count more today @(_moreExpanded ? "↑" : "→")
                    </button>
                }
            </div>

            @if (_moreExpanded && remainingChores.Count > 0)
            {
                <div class="kh-more-list">
                    @foreach (var chore in remainingChores)
                    {
                        <SwipeableChoreCard
                            Chore="@chore"
                            OnComplete="HandleChoreComplete"
                            OnRequestHelp="HandleHelpRequest"
                            OnUndo="HandleChoreUndo"
                            IsProcessing="@(_processingChoreId == chore.ChoreDefinitionId)" />
                    }
                </div>
            }
        }
        else if (_childData.TodayTotalCount > 0)
        {
            <!-- All Done State (celebration surface) -->
            <div class="kh-banner kh-banner-done">
                <div class="kh-banner-icon">⭐</div>
                <div class="kh-banner-text">
                    <strong>Amazing work!</strong>
                    <span>You finished everything today</span>
                </div>
            </div>
        }
        else
        {
            <!-- No Chores Today -->
            <div class="kh-banner">
                <div class="kh-banner-icon-mono">
                    <IconTile IconName="moon" Mono="true" Size="20" />
                </div>
                <div class="kh-banner-text">
                    <strong>Day off</strong>
                    <span>Nothing scheduled for today</span>
                </div>
            </div>
        }

        <!-- COMPLETED: retired into a one-line receipt -->
        @if (_childData.CompletedChores.Count > 0)
        {
            <div class="kh-done">
                <button type="button" class="kh-done-toggle" @onclick="ToggleDoneSection">
                    <span class="kh-done-check">
                        <IconTile IconName="check" Mono="true" Size="14" />
                    </span>
                    <span class="kh-done-title">Done · @_childData.CompletedChores.Count</span>
                    <span class="kh-done-names">@DoneSummary()</span>
                    <span class="kh-done-chevron">
                        <IconTile IconName="@(_doneExpanded ? "chevron-up" : "chevron-down")" Mono="true" Size="14" />
                    </span>
                </button>

                @if (_doneExpanded)
                {
                    <div class="kh-done-list">
                        @foreach (var chore in _childData.CompletedChores)
                        {
                            <div class="kh-done-item">
                                <span class="kh-done-tile">
                                    <IconTile IconName="@chore.LucideIconName" Slot="@chore.TileSlot" Size="22" />
                                </span>
                                <span class="kh-done-name">@chore.ChoreName</span>
                                @if (!chore.IsApproved)
                                {
                                    <span class="kh-done-waiting">waiting for approval</span>
                                }
                                @if (chore.EarnValue > 0)
                                {
                                    <span class="kh-done-value @(chore.IsApproved ? "earned" : "")">
                                        @(chore.IsApproved ? "+" : "")$@chore.EarnValue.ToString("F2")
                                    </span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    @* Fallback: Authenticated user but no data loaded *@
    <EmptyState Type="EmptyStateType.Error" 
                Title="Unable to Load Dashboard"
                Message="We couldn't load your dashboard data. Please try refreshing the page.">
        <ActionButton>
            <button class="btn btn-primary" @onclick="@(() => LoadDashboardAsync())">Try Again</button>
        </ActionButton>
    </EmptyState>
}

@code {
    private bool _isLoading = true;
    private bool _isAuthenticated;
    private bool _isParent;
    private bool _isAdmin;
    private bool _isAdminOnly;
    private string? _userId;
    private string _firstName = string.Empty;
    private bool _showConfetti;
    private bool _hasTriggeredConfetti;
    private bool _initializationComplete;
    
    // Child dashboard state
    private bool _doneExpanded = false;
    private bool _moreExpanded = false;
    private int? _processingChoreId;

    private ParentDashboardData? _parentData;
    private ChildDashboardData? _childData;

    private bool _isApproving;
    private int? _approvingId;

    private CancellationTokenSource? _achievementCts;

    /// <summary>Chore id → (lucide icon, tile slot) so approval rows can show the chore's
    /// IconTile instead of a kid-initial avatar (design #17a). Presentation-only lookup.</summary>
    private Dictionary<int, (string? Icon, int Slot)> _choreTiles = new();

    /// <summary>Single-child households get the card variant with zero other-child cues (#17a).</summary>
    private bool IsSingleChild => _parentData?.ChildrenBalances.Count == 1;

    private string? ChoreTileIcon(int choreDefinitionId) =>
        _choreTiles.TryGetValue(choreDefinitionId, out var tile) ? tile.Icon : null;

    private int ChoreTileSlot(int choreDefinitionId) =>
        _choreTiles.TryGetValue(choreDefinitionId, out var tile) ? tile.Slot : 1;

    private async Task LoadChoreTilesAsync()
    {
        try
        {
            var chores = await ChoreManagementService.GetAllChoresAsync(includeInactive: true);
            _choreTiles = chores.ToDictionary(c => c.Id, c => (c.LucideIconName, c.TileSlot));
        }
        catch (Exception ex)
        {
            // Icon tiles are decorative; rows fall back to the default tile on failure.
            Logger.LogWarning(ex, "Failed to load chore tile metadata for approvals list");
        }
    }

    /// <summary>First weekly-frequency chore's progress — records-strip cell (#12b "WALKS" cell).
    /// Weekly chores always render as counters ("1 of 3"), never day slots.</summary>
    private WeeklyChoreProgress? FirstWeeklyProgress => _childData?.WeeklyProgress?.ChoreProgress.FirstOrDefault();

    private static string WeeklyCellSub(WeeklyChoreProgress weekly)
    {
        if (weekly.QuotaMet) return "done for the week";
        return weekly.PotentialEarnings > 0
            ? $"{weekly.RemainingCount} more → ${weekly.PotentialEarnings:0.##}"
            : $"{weekly.RemainingCount} more this week";
    }

    /// <summary>Inline receipt summary of today's finished chores (first few names).</summary>
    private string DoneSummary()
    {
        if (_childData == null) return string.Empty;
        var names = _childData.CompletedChores.Select(c => c.ChoreName).ToList();
        return names.Count <= 3
            ? string.Join(" · ", names)
            : string.Join(" · ", names.Take(3)) + $" +{names.Count - 3}";
    }

    private static string DayLetter(DateOnly d) => d.DayOfWeek switch
    {
        DayOfWeek.Sunday => "S",
        DayOfWeek.Monday => "M",
        DayOfWeek.Tuesday => "T",
        DayOfWeek.Wednesday => "W",
        DayOfWeek.Thursday => "T",
        DayOfWeek.Friday => "F",
        DayOfWeek.Saturday => "S",
        _ => ""
    };

    private static string FormatDay(decimal amount) => amount > 0 ? "$" + amount.ToString("0.##") : "—";

    private string WeeklyPotentialDisplay()
    {
        if (_parentData == null) return "$0.00";
        return _parentData.WeeklyPotential > 0
            ? $"${_parentData.ThisWeekEarnings:F2} / ${_parentData.WeeklyPotential:F2}"
            : $"${_parentData.ThisWeekEarnings:F2}";
    }

    private decimal WeeklyFillPercent()
    {
        if (_parentData == null || _parentData.WeeklyPotential <= 0) return 0;
        var pct = (_parentData.ThisWeekEarnings / _parentData.WeeklyPotential) * 100m;
        return Math.Clamp(pct, 0m, 100m);
    }

    private decimal WeeklyMarkerPercent()
    {
        return Math.Clamp(WeeklyFillPercent(), 10m, 90m);
    }

    private string HeatmapHeading()
    {
        if (_parentData?.ChildrenBalances.Count == 1)
        {
            return $"{_parentData.ChildrenBalances[0].DisplayName}'s year";
        }
        return "Activity this year";
    }

    private string Greeting()
    {
        // Use the configured family timezone (DateProvider.Now), not the server's
        // clock. The container runs in UTC, so DateTime.Now would report UTC and
        // skew the greeting by hours (e.g. "Good evening" at 1:30 PM Central).
        var hour = DateProvider.Now.Hour;
        if (hour < 12) return "Good morning";
        if (hour < 17) return "Good afternoon";
        return "Good evening";
    }

    private static string GetTimeAgo(DateTime time)
    {
        var diff = DateTime.UtcNow - time;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            _isAuthenticated = user.Identity?.IsAuthenticated == true;

            if (!_isAuthenticated)
            {
                Logger.LogInformation("User is not authenticated");
                _isLoading = false;
                _initializationComplete = true;
                return;
            }

            _userId = user.FindFirstValue(ClaimTypes.NameIdentifier);

            // Greeting name: prefer a given-name claim, else fall back to the username,
            // capitalising the first letter for display (e.g. "shaun" -> "Shaun").
            var rawName = user.FindFirstValue(ClaimTypes.GivenName);
            if (string.IsNullOrWhiteSpace(rawName))
            {
                rawName = user.Identity?.Name;
            }
            if (!string.IsNullOrWhiteSpace(rawName))
            {
                var trimmed = rawName.Trim();
                _firstName = char.ToUpperInvariant(trimmed[0]) + trimmed[1..];
            }

            _isParent = user.IsInRole("Parent");
            _isAdmin = user.IsInRole("Admin");
            _isAdminOnly = user.IsInRole("Admin") && !user.IsInRole("Parent") && !user.IsInRole("Child");

            Logger.LogInformation("User authenticated: UserId={UserId}, IsParent={IsParent}, IsAdmin={IsAdmin}, IsAdminOnly={IsAdminOnly}", 
                _userId, _isParent, _isAdmin, _isAdminOnly);

            // Subscribe to AppStateService events for real-time updates via SignalR
            if (_isParent || _isAdmin)
            {
                AppState.OnParentDashboardChanged += OnParentDashboardStateChanged;
                await LoadChoreTilesAsync();
            }
            else
            {
                AppState.OnChildDashboardChanged += OnChildDashboardStateChanged;
            }

            await LoadDashboardAsync(forceRefresh: true);

            Logger.LogInformation("Dashboard loaded: ParentData={ParentData}, ChildData={ChildData}", 
                _parentData != null, _childData != null);

            if (_childData?.NewAchievements.Count > 0 && !string.IsNullOrEmpty(_userId))
            {
                ScheduleAchievementMarking(_userId);
            }
            
            if (_childData != null && 
                _childData.TodayTotalCount > 0 && 
                _childData.TodayCompletedCount == _childData.TodayTotalCount &&
                !_hasTriggeredConfetti)
            {
                _hasTriggeredConfetti = true;
                _ = Task.Delay(500).ContinueWith(_ => 
                {
                    InvokeAsync(() =>
                    {
                        _showConfetti = true;
                        StateHasChanged();
                    });
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize dashboard");
        }
        finally
        {
            _isLoading = false;
            _initializationComplete = true;
        }
    }

    private async void OnParentDashboardStateChanged()
    {
        // Refresh parent dashboard when SignalR notification triggers cache invalidation
        await InvokeAsync(async () =>
        {
            await LoadDashboardAsync(forceRefresh: true);
            StateHasChanged();
        });
    }

    private async void OnChildDashboardStateChanged()
    {
        // Refresh child dashboard when SignalR notification triggers cache invalidation
        await InvokeAsync(async () =>
        {
            await LoadDashboardAsync(forceRefresh: true);
            CheckAndTriggerConfetti();
            StateHasChanged();
        });
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initializationComplete && _isAuthenticated)
        {
            try
            {
                await LoadDashboardAsync();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load dashboard in OnAfterRenderAsync");
            }
        }
    }
    
    private void CheckAndTriggerConfetti()
    {
        if (_childData != null && 
            _childData.TodayTotalCount > 0 && 
            _childData.TodayCompletedCount == _childData.TodayTotalCount &&
            !_hasTriggeredConfetti)
        {
            _hasTriggeredConfetti = true;
            _ = Task.Delay(500).ContinueWith(_ => 
            {
                InvokeAsync(() =>
                {
                    _showConfetti = true;
                    StateHasChanged();
                });
            });
        }
    }
    
    private void ScheduleAchievementMarking(string userId)
    {
        _achievementCts = new CancellationTokenSource();
        var token = _achievementCts.Token;
        
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(5000, token);
                if (!token.IsCancellationRequested)
                {
                    await AchievementService.MarkAchievementsAsSeenAsync(userId);
                }
            }
            catch (TaskCanceledException)
            {
            }
        }, token);
    }

    private async Task LoadDashboardAsync(bool forceRefresh = false)
    {
        try
        {
            if (_isParent || _isAdmin)
            {
                _parentData = await AppState.GetParentDashboardAsync(forceRefresh);

                // A chore created after page load may appear in approvals before its
                // tile metadata is cached — refresh the lookup so the row gets its icon.
                if (_parentData?.PendingApprovals.Any(a => !_choreTiles.ContainsKey(a.ChoreDefinitionId)) == true)
                {
                    await LoadChoreTilesAsync();
                }
            }
            else if (!string.IsNullOrEmpty(_userId))
            {
                _childData = await AppState.GetChildDashboardAsync(_userId, forceRefresh);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard");
            ToastService.ShowError("Error", $"Failed to load dashboard: {ex.Message}");
        }
    }

    private void ToggleDoneSection()
    {
        _doneExpanded = !_doneExpanded;
    }

    private void ToggleMoreToday()
    {
        _moreExpanded = !_moreExpanded;
    }
    
    private async Task HandleChoreComplete(TrackerChoreItem chore)
    {
        if (string.IsNullOrEmpty(_userId) || _childData == null) return;
        if (_processingChoreId.HasValue) return;
        
        _processingChoreId = chore.ChoreDefinitionId;
        StateHasChanged();
        
        try
        {
            var today = DateProvider.Today;
            var result = await DashboardService.ToggleChoreFromDashboardAsync(
                chore.ChoreDefinitionId,
                today,
                _userId);

            if (result.Success && result.Data != null)
            {
                if (result.Data.IsApproved)
                {
                    // Only show amount if it's greater than $0
                    var message = chore.EarnValue > 0 ? $"+${chore.EarnValue:F2}" : null;
                    ToastService.ShowSuccess("Done!", message);
                }
                else if (result.Data.IsCompleted)
                {
                    ToastService.ShowInfo("Marked!", "Waiting for approval");
                }
                
                AppState.InvalidateChildDashboard(_userId);
                await LoadDashboardAsync(forceRefresh: true);
                
                if (!_hasTriggeredConfetti)
                {
                    CheckAndTriggerConfetti();
                }
            }
            else
            {
                ToastService.ShowError("Error", result.ErrorMessage ?? "Failed to complete chore");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error", ex.Message);
        }
        finally
        {
            _processingChoreId = null;
        }
    }

    private async Task HandleChoreUndo(TrackerChoreItem chore)
    {
        if (string.IsNullOrEmpty(_userId) || _childData == null) return;
        if (_processingChoreId.HasValue) return;

        _processingChoreId = chore.ChoreDefinitionId;
        StateHasChanged();

        try
        {
            var today = DateProvider.Today;
            var result = await DashboardService.UndoLastWeeklyCompletionFromDashboardAsync(
                chore.ChoreDefinitionId,
                today,
                _userId);

            if (result.Success)
            {
                ToastService.ShowInfo("Undone", $"'{chore.ChoreName}' completion was undone.");
                AppState.InvalidateChildDashboard(_userId);
                await LoadDashboardAsync(forceRefresh: true);
            }
            else
            {
                ToastService.ShowError("Error", result.ErrorMessage ?? "Failed to undo chore");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error", ex.Message);
        }
        finally
        {
            _processingChoreId = null;
        }
    }

    private async Task HandleHelpRequest(TrackerChoreItem chore)
    {
        if (string.IsNullOrEmpty(_userId) || _childData == null) return;
        if (_processingChoreId.HasValue) return;
        
        _processingChoreId = chore.ChoreDefinitionId;
        StateHasChanged();
        
        try
        {
            var today = DateProvider.Today;
            var result = await TrackerService.RequestHelpAsync(
                chore.ChoreDefinitionId,
                today,
                _userId,
                "Need help with this");

            if (result.Success)
            {
                ToastService.ShowInfo("Help Requested", "Your parents have been notified");
                AppState.InvalidateChildDashboard(_userId);
                await LoadDashboardAsync(forceRefresh: true);
            }
            else
            {
                ToastService.ShowError("Error", result.ErrorMessage ?? "Failed to request help");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error", ex.Message);
        }
        finally
        {
            _processingChoreId = null;
        }
    }

    private async Task QuickApprove(int choreLogId)
    {
        if (string.IsNullOrEmpty(_userId)) return;

        _isApproving = true;
        _approvingId = choreLogId;
        StateHasChanged(); // Show spinner immediately

        try
        {
            var result = await DashboardService.QuickApproveAsync(choreLogId, _userId);
            
            if (result.Success)
            {
                ToastService.ShowSuccess("Approved!", "Task approved and earnings added.");
                
                // Invalidate caches and reload fresh data
                AppState.InvalidateParentDashboard();
                AppState.InvalidateChildDashboard();
                
                // Reload dashboard with fresh data
                await LoadDashboardAsync(forceRefresh: true);
                
                // Force re-render with updated _parentData
                StateHasChanged();
            }
            else
            {
                ToastService.ShowError("Error", result.ErrorMessage ?? "Failed to approve task.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "QuickApprove exception: ChoreLogId={ChoreLogId}", choreLogId);
            ToastService.ShowError("Error", ex.Message);
        }
        finally
        {
            _isApproving = false;
            _approvingId = null;
            StateHasChanged(); // Reset button state
        }
    }

    public void Dispose()
    {
        _achievementCts?.Cancel();
        _achievementCts?.Dispose();
        
        // Unsubscribe from state change events
        if (_isParent || _isAdmin)
        {
            AppState.OnParentDashboardChanged -= OnParentDashboardStateChanged;
        }
        else
        {
            AppState.OnChildDashboardChanged -= OnChildDashboardStateChanged;
        }
    }
}
