@using Daily_Bread.Data.Models
@using Daily_Bread.Services

<div class="achievement-form-modal">
    <button class="modal-close-absolute" @onclick="HandleCancel" aria-label="Close">×</button>
    <div class="modal-header">
        <h2>@Title</h2>
    </div>
    <div class="modal-body">
        <AchievementForm
            Achievement="Achievement"
            Chores="Chores"
            OnSubmit="OnSubmit"
            OnCancel="HandleCancel" />
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Add Achievement";
    [Parameter] public AchievementDto? Achievement { get; set; }
    [Parameter] public List<ChoreDefinition> Chores { get; set; } = [];
    [Parameter] public EventCallback<AchievementDto> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task HandleCancel() => await OnCancel.InvokeAsync();
}
