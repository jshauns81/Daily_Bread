@using Daily_Bread.Data.Models
@using Daily_Bread.Services
@using System.ComponentModel.DataAnnotations

@* Chore form — design reference #18a (SCREENS_ADDENDUM §18).
   Field model UNCHANGED from beta: identity → Earns/Expected → schedule rule →
   importance (disabled until screen-time mechanics land) → collapsed options → actions.
   Semantic colors teach the form: money = mint, schedule = accent, screen-time = amber. *@

<div class="chore-form">
    <EditForm Model="FormModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <!-- GROUP 1: Identity — tile trigger (#18b picker) + name -->
        <div class="form-section identity-section">
            <div class="icon-picker">
                <IconPicker @bind-IconName="FormModel.LucideIconName" @bind-TileSlot="FormModel.TileSlot" />
            </div>
            <div class="name-field">
                <InputText @bind-Value="FormModel.Name" class="ds-input ds-input--name" placeholder="What's the chore?" />
                <ValidationMessage For="() => FormModel.Name" class="validation-msg" />
            </div>
        </div>

        <!-- GROUP 2: Earns/Expected — money things are mint -->
        <div class="form-section type-section">
            <div class="seg seg--type">
                <div class="seg__item seg__item--earns @(FormModel.ChoreType == ChoreTypeOption.Earning ? "seg__item--active" : "")"
                     role="button" tabindex="0"
                     @onclick="() => SetChoreType(ChoreTypeOption.Earning)"
                     @onkeydown="e => HandleSegKey(e, () => SetChoreType(ChoreTypeOption.Earning))">
                    <span class="seg__label">Earns</span>
                    @if (FormModel.ChoreType == ChoreTypeOption.Earning)
                    {
                        <span class="pay-stepper" @onclick:stopPropagation="true">
                            <button type="button" class="pay-stepper__btn" aria-label="Decrease pay" @onclick="DecrementPay">−</button>
                            <span class="pay-stepper__amount">
                                <span class="pay-stepper__currency">$</span>
                                <InputNumber @bind-Value="FormModel.EarnValue" class="pay-stepper__input" step="0.25" min="0" />
                            </span>
                            <button type="button" class="pay-stepper__btn" aria-label="Increase pay" @onclick="IncrementPay">+</button>
                        </span>
                    }
                </div>
                <div class="seg__item seg__item--expected @(FormModel.ChoreType == ChoreTypeOption.Expectation ? "seg__item--active" : "")"
                     role="button" tabindex="0"
                     @onclick="() => SetChoreType(ChoreTypeOption.Expectation)"
                     @onkeydown="e => HandleSegKey(e, () => SetChoreType(ChoreTypeOption.Expectation))">
                    <span class="seg__label">Expected</span>
                </div>
            </div>
        </div>

        <!-- Assigned To (only if multiple users) -->
        @if (Users.Count > 1)
        {
            <div class="form-section assign-section">
                <label class="field-row">
                    <span class="field-label">For</span>
                    <InputSelect @bind-Value="FormModel.AssignedUserId" class="ds-select">
                        <option value="">Anyone</option>
                        @foreach (var user in Users)
                        {
                            <option value="@user.Id">@user.UserName</option>
                        }
                    </InputSelect>
                </label>
            </div>
        }

        <!-- GROUP 3: Schedule — schedule things are accent -->
        <div class="form-section schedule-section">
            <span class="section-label">Schedule rule</span>
            <div class="seg seg--schedule">
                <button type="button"
                        class="seg__item seg__item--schedule @(FormModel.ScheduleType == ChoreScheduleType.SpecificDays ? "seg__item--active" : "")"
                        @onclick="() => SetScheduleType(ChoreScheduleType.SpecificDays)">
                    <span class="seg__label">Fixed days</span>
                </button>
                <button type="button"
                        class="seg__item seg__item--schedule @(FormModel.ScheduleType == ChoreScheduleType.WeeklyFrequency ? "seg__item--active" : "")"
                        @onclick="() => SetScheduleType(ChoreScheduleType.WeeklyFrequency)">
                    <span class="seg__label">Weekly goal</span>
                </button>
            </div>

            <!-- EITHER days OR frequency, not both -->
            @if (FormModel.ScheduleType == ChoreScheduleType.SpecificDays)
            {
                <div class="days-row">
                    @foreach (var day in DayOptions)
                    {
                        <button type="button"
                                class="day-chip @(IsDaySelected(day.Value) ? "day-chip--selected" : "")"
                                @onclick="() => ToggleDay(day.Value)">
                            @day.Label
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="frequency-row">
                    <span class="frequency-row__text">up to</span>
                    <InputNumber @bind-Value="FormModel.WeeklyTargetCount" class="frequency-row__input" min="1" max="7" />
                    <span class="frequency-row__text">× weekly</span>

                    @if (FormModel.ChoreType == ChoreTypeOption.Earning)
                    {
                        <label class="bonus-toggle">
                            <InputCheckbox @bind-Value="FormModel.IsRepeatable" />
                            <span>Bonus</span>
                        </label>
                    }
                </div>
            }
        </div>

        <!-- GROUP 4: Importance (#6b, amber) — DISABLED until screen-time mechanics ship.
             Display-only: shows the stored weight but never writes it. -->
        <div class="form-section importance-section"
             title="Importance affects screen time — coming with the screen-time update">
            <div class="importance-head">
                <span class="section-label section-label--amber">Importance</span>
                <span class="importance-value">@FormModel.Importance</span>
            </div>
            <div class="importance-slider"
                 role="slider"
                 aria-label="Importance"
                 aria-valuemin="0" aria-valuemax="10" aria-valuenow="@FormModel.Importance"
                 aria-disabled="true">
                <div class="importance-slider__fill" style="width:@(FormModel.Importance * 10)%"></div>
                <span class="importance-slider__thumb" style="left:@(FormModel.Importance * 10)%"></span>
            </div>
            <div class="importance-scale">
                <span>0 · no penalty</span>
                <span>10 · max</span>
            </div>
            <p class="importance-consequence">
                @if (FormModel.Importance > 0)
                {
                    <text>Missing this deducts <span class="importance-consequence__amber">screen time at weight @FormModel.Importance of 10</span>. </text>
                }
                else
                {
                    <text>Missing this deducts <span class="importance-consequence__amber">no screen time</span>. </text>
                }
                <span class="importance-consequence__mint">Pay is never affected.</span>
            </p>
            <p class="importance-coming">Coming with the screen-time update</p>
        </div>

        <!-- Options (collapsed) - reduced visual weight -->
        <details class="options-section">
            <summary class="options-summary">
                <svg class="options-summary__gear" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                <span class="options-summary__title">Options</span>
                <span class="options-summary__hint">auto-approve · active · dates · notes</span>
                <svg class="options-summary__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="options-content">
                <label class="option-check @(FormModel.ChoreType != ChoreTypeOption.Earning ? "option-check--disabled" : "")">
                    <InputCheckbox @bind-Value="FormModel.AutoApprove"
                                   disabled="@(FormModel.ChoreType != ChoreTypeOption.Earning)" />
                    <span>Auto-approve completions</span>
                </label>
                <label class="option-check">
                    <InputCheckbox @bind-Value="FormModel.IsActive" />
                    <span>Active</span>
                </label>
                <div class="date-row">
                    <label class="date-field">
                        <span>Start</span>
                        <InputDate @bind-Value="FormModel.StartDate" class="ds-input ds-input--date" />
                    </label>
                    <label class="date-field">
                        <span>End</span>
                        <InputDate @bind-Value="FormModel.EndDate" class="ds-input ds-input--date" />
                    </label>
                </div>
                <InputTextArea @bind-Value="FormModel.Description" class="ds-input ds-input--textarea" rows="2" placeholder="Notes (optional)" />
            </div>
        </details>

        <!-- Actions: delete = risk color, never a primary position -->
        <div class="form-actions">
            @if (IsEditing && OnDelete.HasDelegate)
            {
                <button type="button" class="btn-delete" @onclick="HandleDelete">Delete</button>
            }
            <button type="button" class="btn-cancel" @onclick="HandleCancel">Cancel</button>
            <button type="submit" class="btn-submit" disabled="@IsSubmitting">
                @if (IsSubmitting) { <span class="spinner"></span> }
                @(IsEditing ? "Save" : "Create")
            </button>
        </div>
    </EditForm>
</div>

@code {
    private enum ChoreTypeOption { Earning, Expectation }

    [Parameter] public ChoreDefinitionDto? Chore { get; set; }
    [Parameter] public List<UserSelectItem> Users { get; set; } = [];
    [Parameter] public EventCallback<ChoreDefinitionDto> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    /// <summary>Optional: when supplied (and editing), renders the risk-colored Delete action.</summary>
    [Parameter] public EventCallback OnDelete { get; set; }

    private ChoreFormModel FormModel { get; set; } = new();
    private bool IsEditing => Chore?.Id > 0;
    private bool IsSubmitting { get; set; }

    private static readonly List<(DaysOfWeek Value, string Label)> DayOptions =
    [
        (DaysOfWeek.Sunday, "S"),
        (DaysOfWeek.Monday, "M"),
        (DaysOfWeek.Tuesday, "T"),
        (DaysOfWeek.Wednesday, "W"),
        (DaysOfWeek.Thursday, "T"),
        (DaysOfWeek.Friday, "F"),
        (DaysOfWeek.Saturday, "S")
    ];

    protected override void OnParametersSet()
    {
        if (Chore != null)
        {
            FormModel = new ChoreFormModel
            {
                Id = Chore.Id,
                Name = Chore.Name,
                Description = Chore.Description,
                Icon = Chore.Icon,
                LucideIconName = Chore.LucideIconName,
                TileSlot = Chore.TileSlot is >= 1 and <= 5 ? Chore.TileSlot : 1,
                AssignedUserId = Chore.AssignedUserId,
                EarnValue = Chore.EarnValue,
                Importance = Chore.Importance,
                AllOrNothing = Chore.AllOrNothing,
                IsInverseFill = Chore.IsInverseFill,
                InverseFillBaselineMinutes = Chore.InverseFillBaselineMinutes,
                ScheduleType = Chore.ScheduleType,
                ActiveDays = Chore.ActiveDays,
                WeeklyTargetCount = Chore.WeeklyTargetCount,
                IsRepeatable = Chore.IsRepeatable,
                StartDate = Chore.StartDate,
                EndDate = Chore.EndDate,
                IsActive = Chore.IsActive,
                AutoApprove = Chore.AutoApprove,
                SortOrder = Chore.SortOrder,
                ChoreType = Chore.Kind == ChoreKind.Task ? ChoreTypeOption.Earning : ChoreTypeOption.Expectation
            };
        }
        else
        {
            FormModel = new ChoreFormModel
            {
                ChoreType = ChoreTypeOption.Earning,
                ScheduleType = ChoreScheduleType.SpecificDays,
                ActiveDays = DaysOfWeek.All,
                WeeklyTargetCount = 1,
                IsRepeatable = false,
                IsActive = true,
                AutoApprove = true,
                EarnValue = 1.00m
            };
        }

        if (Users.Count == 1 && string.IsNullOrEmpty(FormModel.AssignedUserId))
            FormModel.AssignedUserId = Users[0].Id;
    }

    private void SetChoreType(ChoreTypeOption type)
    {
        FormModel.ChoreType = type;
        if (type == ChoreTypeOption.Earning)
        {
            if (FormModel.EarnValue <= 0) FormModel.EarnValue = 1.00m;
        }
        else
        {
            FormModel.EarnValue = 0;
            FormModel.AutoApprove = true;
            FormModel.IsRepeatable = false;
        }
    }

    private void HandleSegKey(KeyboardEventArgs e, Action action)
    {
        if (e.Key is "Enter" or " " or "Spacebar")
            action();
    }

    private void DecrementPay() =>
        FormModel.EarnValue = Math.Max(0m, FormModel.EarnValue - 0.25m);

    private void IncrementPay() =>
        FormModel.EarnValue = Math.Min(10000m, FormModel.EarnValue + 0.25m);

    private void SetScheduleType(ChoreScheduleType type)
    {
        FormModel.ScheduleType = type;
        if (type == ChoreScheduleType.WeeklyFrequency && FormModel.ActiveDays == DaysOfWeek.None)
            FormModel.ActiveDays = DaysOfWeek.All;
        if (type == ChoreScheduleType.SpecificDays)
            FormModel.IsRepeatable = false;
    }

    private bool IsDaySelected(DaysOfWeek day) => FormModel.ActiveDays.HasFlag(day);

    private void ToggleDay(DaysOfWeek day)
    {
        FormModel.ActiveDays = FormModel.ActiveDays.HasFlag(day)
            ? FormModel.ActiveDays & ~day
            : FormModel.ActiveDays | day;
    }

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        try
        {
            var dto = new ChoreDefinitionDto
            {
                Id = FormModel.Id,
                Name = FormModel.Name,
                Description = FormModel.Description,
                Icon = FormModel.Icon,
                LucideIconName = FormModel.LucideIconName,
                TileSlot = FormModel.TileSlot,
                AssignedUserId = string.IsNullOrEmpty(FormModel.AssignedUserId) ? null : FormModel.AssignedUserId,
                Kind = FormModel.ChoreType == ChoreTypeOption.Earning ? ChoreKind.Task : ChoreKind.Routine,
                EarnValue = FormModel.ChoreType == ChoreTypeOption.Earning ? FormModel.EarnValue : 0,
                // Importance is display-only until the screen-time mechanics UI lands (Phase 8):
                // the disabled slider never writes it, but the stored weight round-trips untouched.
                Importance = FormModel.Importance,
                AllOrNothing = FormModel.AllOrNothing,
                IsInverseFill = FormModel.IsInverseFill,
                InverseFillBaselineMinutes = FormModel.InverseFillBaselineMinutes,
                ScheduleType = FormModel.ScheduleType,
                ActiveDays = FormModel.ActiveDays,
                WeeklyTargetCount = FormModel.WeeklyTargetCount,
                IsRepeatable = FormModel.ScheduleType == ChoreScheduleType.WeeklyFrequency && FormModel.ChoreType == ChoreTypeOption.Earning
                    ? FormModel.IsRepeatable : false,
                StartDate = FormModel.StartDate,
                EndDate = FormModel.EndDate,
                IsActive = FormModel.IsActive,
                AutoApprove = FormModel.ChoreType == ChoreTypeOption.Expectation ? true : FormModel.AutoApprove,
                SortOrder = FormModel.SortOrder
            };
            await OnSubmit.InvokeAsync(dto);
        }
        finally { IsSubmitting = false; }
    }

    private async Task HandleCancel() => await OnCancel.InvokeAsync();

    private async Task HandleDelete() => await OnDelete.InvokeAsync();

    private class ChoreFormModel
    {
        public int Id { get; set; }
        public ChoreTypeOption ChoreType { get; set; } = ChoreTypeOption.Earning;
        [Required(ErrorMessage = "Required")]
        [StringLength(100)]
        public string Name { get; set; } = string.Empty;
        [StringLength(500)]
        public string? Description { get; set; }
        public string? Icon { get; set; }
        public string? LucideIconName { get; set; }
        /// <summary>0 = untouched on a new chore; the service assigns a rotating slot on create.</summary>
        public int TileSlot { get; set; }
        public string? AssignedUserId { get; set; }
        [Range(0, 10000)]
        public decimal EarnValue { get; set; }
        /// <summary>Screen-time importance weight 0–10. Display-only in this form (Phase 8 edits it).</summary>
        public int Importance { get; set; }
        /// <summary>Mechanics passthrough — not edited here; preserved so saving never wipes it.</summary>
        public bool AllOrNothing { get; set; } = true;
        /// <summary>Mechanics passthrough — not edited here; preserved so saving never wipes it.</summary>
        public bool IsInverseFill { get; set; }
        /// <summary>Mechanics passthrough — not edited here; preserved so saving never wipes it.</summary>
        public int InverseFillBaselineMinutes { get; set; } = 20;
        public ChoreScheduleType ScheduleType { get; set; } = ChoreScheduleType.SpecificDays;
        public DaysOfWeek ActiveDays { get; set; } = DaysOfWeek.All;
        [Range(1, 7)]
        public int WeeklyTargetCount { get; set; } = 1;
        public bool IsRepeatable { get; set; }
        public DateOnly? StartDate { get; set; }
        public DateOnly? EndDate { get; set; }
        public bool IsActive { get; set; } = true;
        public bool AutoApprove { get; set; } = true;
        public int SortOrder { get; set; }
    }
}
